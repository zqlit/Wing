---
const navItems = [
  { href: "/", label: "首页" },
  { href: "/archive", label: "归档" },
  { href: "/links", label: "友链" },
  { href: "/about", label: "关于" },
];
---

<header class="sticky top-4 z-50 mx-auto max-w-fit">
  <div class="flex items-center gap-1 px-2 py-2 rounded-full bg-white/70 dark:bg-[#0f172a]/70 backdrop-blur-xl border border-white/20 dark:border-white/10 shadow-lg shadow-black/5 dark:shadow-black/20">
    <!-- Logo -->
    <a 
      href="/" 
      class="px-4 py-1.5 text-sm font-medium text-[#111827] dark:text-[#f8fafc] hover:bg-black/5 dark:hover:bg-white/10 rounded-full transition-all"
      aria-label="首页"
    >
      5b2
    </a>

    <!-- 分隔线 -->
    <div class="w-px h-4 bg-[#e5e7eb] dark:bg-[#374151]"></div>

    <!-- 导航链接 -->
    <nav class="flex items-center">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="px-4 py-1.5 text-sm text-[#374151] dark:text-[#9ca3af] hover:text-[#111827] dark:hover:text-[#f8fafc] hover:bg-black/5 dark:hover:bg-white/10 rounded-full transition-all"
          data-nav-link
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- 分隔线 -->
    <div class="w-px h-4 bg-[#e5e7eb] dark:bg-[#374151]"></div>

    <!-- 主题切换按钮 -->
    <button
      id="theme-toggle"
      class="px-3 py-1.5 text-sm text-[#374151] dark:text-[#9ca3af] hover:text-[#111827] dark:hover:text-[#f8fafc] hover:bg-black/5 dark:hover:bg-white/10 rounded-full transition-all cursor-pointer"
      aria-label="切换主题"
    >
      <span class="dark:hidden text-base">☀</span>
      <span class="hidden dark:inline text-base">☾</span>
    </button>
  </div>
</header>

<script is:inline>
  const html = document.documentElement;
  
  const getIsDark = () => {
    const savedTheme = localStorage.getItem('theme');
    const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    return savedTheme ? savedTheme === 'dark' : isSystemDark;
  };

  const initTheme = () => {
    const isDark = getIsDark();
    html.classList[isDark ? 'add' : 'remove']('dark');
  };

  const toggleTheme = () => {
    const isDark = html.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  };

  document.addEventListener('astro:after-swap', () => {
    initTheme();
    const themeToggle = document.getElementById('theme-toggle');
    themeToggle?.removeEventListener('click', toggleTheme);
    themeToggle?.addEventListener('click', toggleTheme);
  });

  initTheme();
  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
</script>