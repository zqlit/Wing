---
import { SITE_CONFIG } from "../config";

const navItems = [
  { href: "/", label: "首页" },
  { href: "/archive", label: "归档" },
  { href: "/links", label: "友链" },
  { href: "/about", label: "关于" },
];
---

<header class="flex items-center justify-between h-6">
  <!-- Logo - 点击切换主题 -->
  <button
    id="theme-toggle"
    class="text-xl font-semibold text-[#111827] dark:text-[#f8fafc] hover:opacity-70 transition-opacity cursor-pointer"
    aria-label="切换主题"
  >
    Blog
  </button>

  <!-- 导航链接 -->
  <nav class="flex items-center space-x-6">
    {navItems.map((item) => (
      <a
        href={item.href}
        class="text-sm font-semibold text-[#111827] dark:text-[#f8fafc] hover:opacity-70 transition-opacity"
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>

<script is:inline>
  const html = document.documentElement;
  
  const getIsDark = () => {
    const savedTheme = localStorage.getItem('theme');
    const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    return savedTheme ? savedTheme === 'dark' : isSystemDark;
  };

  const initTheme = () => {
    const isDark = getIsDark();
    html.classList[isDark ? 'add' : 'remove']('dark');
  };

  const toggleTheme = () => {
    const isDark = html.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  };

  document.addEventListener('astro:after-swap', () => {
    initTheme();
    const themeToggle = document.getElementById('theme-toggle');
    themeToggle?.removeEventListener('click', toggleTheme);
    themeToggle?.addEventListener('click', toggleTheme);
  });

  initTheme();
  document.getElementById('theme-toggle')?.addEventListener('click', toggleTheme);
</script>