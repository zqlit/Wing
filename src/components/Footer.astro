---
import { SITE_CONFIG } from "../config";

const today = new Date();
---

<footer class="py-12 mt-auto">
  <div class="flex flex-col items-center gap-6">
    <!-- 社交链接 -->
    <div class="flex items-center gap-4">
      <!-- GitHub -->
      <a 
        href="https://github.com/zqlit/Wing" 
        target="_blank"
        rel="noopener noreferrer"
        class="text-[#9ca3af] dark:text-[#64748b] hover:text-[#111827] dark:hover:text-[#f8fafc] transition-colors"
        aria-label="GitHub"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
        </svg>
      </a>
      <!-- RSS -->
      <a 
        href="/rss.xml" 
        class="text-[#9ca3af] dark:text-[#64748b] hover:text-[#111827] dark:hover:text-[#f8fafc] transition-colors"
        aria-label="RSS 订阅"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 11a9 9 0 0 1 9 9"></path>
          <path d="M4 4a16 16 0 0 1 16 16"></path>
          <circle cx="5" cy="19" r="1"></circle>
        </svg>
      </a>
    </div>
    
    <!-- 版权信息 -->
    <div class="text-center text-sm text-[#9ca3af] dark:text-[#64748b] space-y-1">
      <p>
        &copy; {today.getFullYear()} 
        <a href="https://github.com/zqlit" target="_blank" rel="noopener noreferrer" class="hover:text-[#111827] dark:hover:text-[#f8fafc] transition-colors">
          {SITE_CONFIG.author}
        </a>
      </p>
      <p class="text-xs">
        Powered by <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="hover:text-[#111827] dark:hover:text-[#f8fafc] transition-colors">Astro</a>
      </p>
    </div>
  </div>
</footer>
