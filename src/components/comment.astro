---
import type { CollectionEntry } from "astro:content";
import ArtalkComment from "./ArtalkComment.astro";
import GiscusComment from "./GiscusComment.astro";
import TwikooComment from "./TwikooComment.astro";
import { COMMENT_CONFIG } from "../config";

interface Props {
  post: any;
  system?: "artalk" | "giscus" | "twikoo";
}

const { post, system = "artalk" } = Astro.props;
const path = Astro.url.pathname;

// 如果评论被禁用，不渲染任何内容
if (!COMMENT_CONFIG.enabled || COMMENT_CONFIG.system === "none") {
  return null;
}

// 使用配置中的评论系统
const activeSystem = COMMENT_CONFIG.enabled ? COMMENT_CONFIG.system : system;
---

<div class="mt-12">
  {activeSystem === "artalk" && <ArtalkComment pageKey={path} />}
  {activeSystem === "giscus" && <GiscusComment path={path} />}
  {activeSystem === "twikoo" && <TwikooComment path={path} />}
</div>