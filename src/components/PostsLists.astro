---
import { formatDateKey } from "../utils/dataFormatte";

interface Props {
  posts?: any[];
}

// 如果没有传入 posts，则从集合中获取（向后兼容）
let { posts } = Astro.props;

if (!posts) {
  const { getCollection } = await import("astro:content");
  posts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
}

// 格式化日期为 YYYY-MM-DD
function formatSimpleDate(date: Date): string {
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  return `${year}-${month}-${day}`;
}
---

<div>
{
  posts.map((post) => {
    const key = formatDateKey(post.data.pubDate);
    return (
      <article class="border-b border-[#e5e7eb] dark:border-[#374151] pb-2">
        <a href={`/${key}.html`} class="block">
          <h2 class="text-2xl font-bold text-[#111827] dark:text-[#f8fafc] mt-10 mb-2 leading-8">
            {post.data.title}
          </h2>
          <time class="text-sm text-[#6b7280] dark:text-[#9ca3af] block">
            {formatSimpleDate(post.data.pubDate)}
          </time>
        </a>
      </article>
    );
  })
}
</div>

