---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostsLists from "../../components/PostsLists.astro";
import { getCollection } from "astro:content";
import { PAGINATION_CONFIG } from "../../config";

const allPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const POSTS_PER_PAGE = PAGINATION_CONFIG.postsPerPage;
const { page } = Astro.params;
const currentPage = parseInt(page || "1");

if (currentPage < 1 || isNaN(currentPage)) {
  return Astro.redirect("/");
}

const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);

if (currentPage > totalPages) {
  return Astro.redirect("/");
}

const start = (currentPage - 1) * POSTS_PER_PAGE;
const posts = allPosts.slice(start, start + POSTS_PER_PAGE);

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");
  const POSTS_PER_PAGE = PAGINATION_CONFIG.postsPerPage;
  const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);

  return Array.from({ length: totalPages - 1 }, (_, i) => ({
    params: { page: String(i + 2) }
  }));
}
---

<BaseLayout>
  <PostsLists posts={posts} />

  <nav class="flex items-center justify-center gap-6 mt-12">
    {Array.from({ length: totalPages }, (_, i) => {
      const pageNum = i + 1;
      const isActive = pageNum === currentPage;
      return (
        <a
          href={pageNum === 1 ? '/' : `/page/${pageNum}`}
          class={`text-sm font-medium transition-colors hover:text-blue-600 ${
            isActive
              ? 'text-slate-900 dark:text-slate-50'
              : 'text-gray-500 dark:text-gray-400'
          }`}
        >
          {pageNum}
        </a>
      );
    })}
  </nav>
</BaseLayout>
