---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { formatDateKey } from "../utils/dataFormatte";

// 获取所有文章并按日期排序
const allPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// 按年份分组
const postsByYear = allPosts.reduce((acc, post) => {
  const year = post.data.pubDate.getFullYear();
  if (!acc[year]) {
    acc[year] = [];
  }
  acc[year].push(post);
  return acc;
}, {} as Record<number, typeof allPosts>);

// 获取年份并排序（从新到旧）
const years = Object.keys(postsByYear).map(Number).sort((a, b) => b - a);
---

<BaseLayout title="归档" description="文章归档">
  <article>
    <h1 class="text-4xl font-extrabold text-[#111827] dark:text-[#f8fafc] mb-8">归档</h1>
    <hr class="border-t border-[#e5e7eb] dark:border-[#374151] mb-12">
    
    <div class="space-y-10">
      {years.map((year) => (
        <section>
          <h2 class="text-2xl font-bold text-[#111827] dark:text-[#f8fafc] mb-4">{year}</h2>
          <div class="space-y-2">
            {postsByYear[year].map((post) => {
              const key = formatDateKey(post.data.pubDate);
              const month = String(post.data.pubDate.getMonth() + 1).padStart(2, '0');
              const day = String(post.data.pubDate.getDate()).padStart(2, '0');
              return (
                <a
                  href={`/${key}.html`}
                  class="flex items-baseline gap-4 text-[#111827] dark:text-[#f8fafc] hover:opacity-70 transition-opacity"
                >
                  <time class="text-sm text-[#6b7280] dark:text-[#9ca3af] min-w-[44px]">
                    {month}/{day}
                  </time>
                  <span class="text-base">
                    {post.data.title}
                  </span>
                </a>
              );
            })}
          </div>
        </section>
      ))}
    </div>
  </article>
</BaseLayout>
