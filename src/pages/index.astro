---
import BaseLayout from "../themes/ershiliu/layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { formatISODate } from "../utils/dataFormatte";

const allPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const uniquePosts = [...new Map(allPosts.map(post => [post.id, post])).values()];
---

<BaseLayout title="小赵">
  <div>
    {uniquePosts.map((post) => (
      <article key={post.id} class="py-4 border-b border-gray-200 dark:border-gray-700">
        <a href={`/posts/${post.id}`} class="text-slate-900 dark:text-slate-50 hover:text-blue-600 dark:hover:text-blue-400 no-underline block">
          <h2 class="font-bold text-xl md:text-2xl mb-2">{post.data.title}</h2>
        </a>
        <time datetime={new Date(post.data.pubDate).toISOString()} class="text-base text-gray-500 dark:text-gray-400">
          {formatISODate(post.data.pubDate)}
        </time>
      </article>
    ))}
  </div>
</BaseLayout>
